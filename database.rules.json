{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "products": {
      ".indexOn": ["serialId", "serialHash", "status", "batchHash", "batchId", "manufacturerName", "currentOwner", "createdAt"]
    },
    "transfers": {
      ".indexOn": ["serialId", "serialHash", "status", "fromRole", "toRole", "createdAt", "updatedAt"]
    },
    "risk-flags": {
      ".indexOn": ["serialId", "serialHash", "status", "createdAt"]
    },
    "recalls": {
      ".indexOn": ["batchHash", "batchId", "status", "createdAt"]
    },
    "batches": {
      ".indexOn": ["batchId", "batchHash", "manufacturerName", "createdAt"]
    },
    "pending-transfers": {
      ".indexOn": ["serialId", "serialHash"]
    },
    "serial-index": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
