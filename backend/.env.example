# ======== Blockchain & RPC ========
# Local Hardhat Node
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545

# Local Hardhat demo private keys.
# These are placeholders. Teammates can copy real local keys from `npx.cmd hardhat node`.
BACKEND_PRIVATE_KEY=<hardhat_account_0_private_key>
ADMIN_PRIVATE_KEY=<hardhat_account_0_private_key>
MANUFACTURER_PRIVATE_KEY=<hardhat_account_0_private_key>
IMPORTER_PRIVATE_KEY=<hardhat_account_1_private_key>
DISTRIBUTOR_PRIVATE_KEY=<hardhat_account_2_private_key>
CLINIC_PRIVATE_KEY=<hardhat_account_3_private_key>
PHARMACY_PRIVATE_KEY=<hardhat_account_4_private_key>

# Smart Contract Addresses
# Fill these after running:
# npx.cmd hardhat run scripts/deploy.ts --network localhost
PRODUCT_REGISTRY_ADDRESS=<product_registry_address>
TRANSFER_LEDGER_ADDRESS=<transfer_ledger_address>
ACCESS_CONTROL_ADDRESS=<access_control_address>

# ======== IPFS / Pinata ========
# Share this privately, not through git.
PINATA_JWT=<pinata_jwt>

# ======== Firebase ========
# Share these privately, not through git.
FIREBASE_PROJECT_ID=<firebase_project_id>
FIREBASE_DATABASE_URL=<firebase_realtime_database_url>
FIREBASE_PRIVATE_KEY="<firebase_private_key_with_escaped_newlines>"
FIREBASE_CLIENT_EMAIL=<firebase_service_account_email>
FIREBASE_CLIENT_ID=<firebase_client_id>

# ======== Auth & JWT ========
JWT_SECRET=<random_32_byte_hex_or_long_secret>

# ======== Server ========
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug
