NEXT_PUBLIC_APP_NAME=Vaccine Traceability

# Local development:
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_CONSUMER_VERIFY_BASE_URL=http://localhost:3000/consumer/verify

# Production/Vercel:
# NEXT_PUBLIC_API_URL=https://vaccine-traceability-blockchain.onrender.com
# NEXT_PUBLIC_CONSUMER_VERIFY_BASE_URL=https://vaccine-traceability-blockchain.vercel.app/consumer/verify

NEXT_PUBLIC_IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
NEXT_PUBLIC_CHAIN_EXPLORER_BASE_URL=https://sepolia.etherscan.io
NEXT_PUBLIC_SEPOLIA_RPC_URL=<sepolia_rpc_url_from_alchemy_or_infura>
NEXT_PUBLIC_ENABLE_LOCAL_CHAIN=true

# Frontend runs at:
# http://localhost:3000

# Backend API should run at:
# Local: http://localhost:5000
# Production Render: https://vaccine-traceability-blockchain.onrender.com
